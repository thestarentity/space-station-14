ent-ShuttleGunBase = canhão de nave

ent-ShuttleGunSvalinnMachineGun = LSE-400c "metralhadora Svalinn"
    .desc = Unidade laser estacionária básica. Eficiente contra alvos vivos e eletrônicos. Utiliza células de energia comuns para disparar, e possui uma taxa de fogo extremamente alta.

ent-ShuttleGunPerforator = LSE-1200c "Perfurador"
    .desc = Unidade laser estacionária avançada. Aniquila eletrônicos e é extremamente perigosa para a saúde! Utiliza a gaiola de energia para atirar.

ent-ShuttleGunFriendship = EXP-320g "Amizade"
    .desc = Um lançador de granadas pequeno e fixo que comporta 2 granadas.

ent-ShuttleGunDuster = EXP-2100g "Duster"
    .desc = Um poderoso lançador de granadas estacionário. É necessário um cartucho para uso.

ent-ShuttleGunPirateCannon = canhão de navio pirata
    .desc = Kabum!

ent-ShuttleGunKinetic = PTK-800 "Dematerializador de Matéria"
    .desc = Resgatar uma torre de mineração estacionária. Acumula cargas gradualmente por conta própria, extremamente eficaz para a exploração de asteroides.

ent-ShuttleGunKineticOld = dematerializador exomórfico
    .desc = Um antigo canhão de nave, que utiliza sistemas biomecânicos para armazenar e liberar energia. Embora único em seu design, foi considerado obsoleto devido à sua inferior velocidade de carregamento e disparo em comparação com construções mecânicas.
