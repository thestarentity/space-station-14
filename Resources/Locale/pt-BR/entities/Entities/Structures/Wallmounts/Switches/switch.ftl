ent-SignalSwitch = interruptor de sinal
    .desc = É um interruptor para alternar a energia para coisas.

ent-SignalButton = botão de sinal
    .desc = É um botão para ativar algo.

ent-ApcNetSwitch = comutador de rede APC
    .desc = É um interruptor para alternar as luzes conectadas à mesma APC.

ent-SignalSwitchDirectional = interruptor de sinal

ent-SignalButtonDirectional = botão de sinal

ent-ApcNetSwitchDirectional = comutador de rede APC

ent-LockableButton = botão trancável

ent-ButtonFrame = quadro do botão
    .desc = É um quadro para ajudar a distinguir visualmente interruptores.
