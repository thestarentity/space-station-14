ent-MagazineLightRifleEmpty = carregador (.30 rifle qualquer)
    .desc = Mago de 30 rounds duplo empilhado curvado para rifles de combate.

ent-MagazineLightRiflePractice = carregador (.30 rifle practice)
    .desc = Carregador curvado de 30 munições em duplo empilhamento para rifles de combate. Intendido para conter munição de prática inofensiva.

ent-MagazineLightRifleUranium = carregador (.30 rifle urânio)
