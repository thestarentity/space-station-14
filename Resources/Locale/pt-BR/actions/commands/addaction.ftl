# addaction
cmd-addaction-desc = Adiciona uma ação à entidade-alvo. A ação não funcionará se a entidade-alvo exigir um componente adicional em sua entidade (como Devorador de Dragões).
cmd-addaction-help = adicionar ação <EntityUid> <ActionPrototype>
cmd-addaction-invalid-args = Esperado exatamente 2 argumentos.
cmd-addaction-actions-not-found = A entidade-alvo não pode usar ações.
cmd-addaction-action-not-found = Não foi possível encontrar o protótipo de ação correspondente { $action }.
cmd-addaction-adding-failed = Falha ao adicionar a ação.
cmd-addaction-player-completion = <EntityUid>
cmd-addaction-action-completion = Ação concluída.
