delivery-recipient-examine = Este é destinado a { $recipient }, { $job }.
delivery-already-opened-examine = Já estava aberta.
delivery-earnings-examine = Entregar isso ganhará para a estação [color=yellow]{ $spesos }[/color] spesos.
delivery-recipient-no-name = Sem nome
delivery-recipient-no-job = ID desconhecido
delivery-unlocked-self = Você desbloqueia o { $delivery } com sua impressão digital.
delivery-opened-self = Você abre o { $delivery }.
delivery-unlocked-others = { CAPITALIZE($recipient) } desbloqueou o { $delivery } com a impressão digital de { POSS-ADJ($possadj) }.
delivery-opened-others = { CAPITALIZE($recipient) } abriu o { $delivery }.
delivery-unlock-verb = Desbloquear
delivery-open-verb = Aberto
delivery-slice-verb = Cortar abertamente
delivery-teleporter-amount-examine =
    { $amount ->
        [one] Ele contém [color=yellow]{ $amount }[/color] entrega.
       *[other] Ele contém [color=yellow]{ $amount }[/color] entregas.
    }
delivery-teleporter-empty = O { $entity } está vazio.
delivery-teleporter-empty-verb = Receber correio
# modifiers
delivery-priority-examine = Isso é uma [color=orange]prioridade { $type }[/color]. Você tem [color=orange]{ $time }[/color] restantes para entregá-la e obter um bônus.
delivery-priority-delivered-examine = Este é um [color=orange]prioridade { $type }[/color]. Ele foi entregue no prazo.
delivery-priority-expired-examine = Este é um [color=orange]prioridade { $type }[/color]. Ele expirou.
delivery-fragile-examine = Isso é um [color=red]objeto frágil { $type }[/color]. Entregue-o intacto para obter um bônus.
delivery-fragile-broken-examine = Isso é um [color=red]objeto frágil { $type }[/color]. Parece estar muito danificado.
delivery-bomb-examine = Isso é uma [color=purple]bomba { $type }[/color]. Oh não.
delivery-bomb-primed-examine = Isso é uma [color=purple]bomba { $type }[/color]. Ler isso é um mau uso do seu tempo.
