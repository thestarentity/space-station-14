### Loc for the pneumatic cannon.

pneumatic-cannon-component-itemslot-name = Tanque de Gás

## Shown when trying to fire, but no gas

pneumatic-cannon-component-fire-no-gas = { CAPITALIZE(THE($cannon)) } cliques, mas nenhum gás sai.

## Shown when changing power.

pneumatic-cannon-component-change-power =
    { $power ->
        [High] Você configurou o limitador para potência máxima. Parece um pouco muito poderoso...
        [Medium] Você configurou o limitador para potência média.
       *[Low] Você configurou o limitador para baixa potência.
    }

## Shown when being stunned by having the power too high.

pneumatic-cannon-component-power-stun = A força pura de { THE($cannon) } te derruba!
