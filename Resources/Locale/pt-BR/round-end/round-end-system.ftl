## RoundEndSystem

round-end-system-shuttle-called-announcement = Um shuttle de emergência foi enviado. ETA: { $time } { $units }.
round-end-system-shuttle-already-called-announcement = Já foi enviado um shuttle de emergência.
round-end-system-shuttle-auto-called-announcement = Um shuttle automático para troca de turno foi enviado. Previsão de chegada: { $time } { $units }. Chame de volta o shuttle para prolongar o turno.
round-end-system-shuttle-recalled-announcement = O shuttle de emergência foi chamado de volta.
round-end-system-shuttle-sender-announcement = Estação
round-end-system-round-restart-eta-announcement = Reiniciando a rodada em { $time } { $units }...
eta-units-minutes =
    { $amount ->
        [one] minuto
       *[other] minutos
    }
eta-units-seconds =
    { $amount ->
        [one] segundo
       *[other] segundos
    }
