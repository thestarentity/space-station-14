ghost-role-information-guardian-name = Guardião
ghost-role-information-guardian-description = Ouça seu dono. Não suporte danos. Dê socos com força.
ghost-role-information-holoparasite-name = Parasita Holográfico
ghost-role-information-holoparasite-description = Ouça seu dono. Não suporte danos. Dê socos com força.
