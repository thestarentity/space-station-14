ghost-role-information-xeno-description = Você é um xeno, coopere com sua colônia para matar todos os tripulantes!
ghost-role-information-xeno-rules = Você é um [color={ role-type-team-antagonist-color }][bold]{ role-type-team-antagonist-name }[/bold][/color] com todos os outros xenos.
ghost-role-information-revenant-name = Revenante
ghost-role-information-revenant-description = Você é um Revenante. Use seus poderes para coletar almas e desencadear caos entre a tripulação. Desbloqueie novas habilidades com a essência que coleta.
ghost-role-information-kangaroo-name = Canguru
