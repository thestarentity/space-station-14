ghost-role-information-giant-spider-name = Aranha Gigante
ghost-role-information-giant-spider-description = Os habitantes desta estação parecem muito apetitosos, e sua teia pegajosa é perfeita para capturá-los!
ghost-role-information-giant-spider-rules = Você é um [color={ role-type-team-antagonist-color }][bold]{ role-type-team-antagonist-name }[/bold][/color] com todos os outros aranhas gigantes.
ghost-role-information-cognizine-description = Tornou-se consciente com a magia da cognizine.
ghost-role-information-hamster-name = Hamster
