### UI

paper-ui-blank-page-message = Esta página foi deixada intencionalmente em branco
# Shown when paper with words examined details
paper-component-examine-detail-has-words = { CAPITALIZE(THE($paper)) } tem algo escrito nele.
# Shown when paper with stamps examined
paper-component-examine-detail-stamped-by = { CAPITALIZE(THE($paper)) } { CONJUGATE-HAVE($paper) } foi carimbado por: { $stamps }.
paper-component-illiterate = Você é incapaz de escrever.
paper-component-illiterate-mime = O seu juramento proíbe você de escrever.
paper-component-action-stamp-paper-other = { CAPITALIZE(THE($user)) } carimpa { THE($target) } com { THE($stamp) }.
paper-component-action-stamp-paper-self = Você carimba { THE($target) } com { THE($stamp) }.
# Indicator to show how full a paper is
paper-ui-fill-level = { $currentLength }/{ $maxLength }
paper-ui-save-button = Salvar ({ $keybind })
paper-tamper-proof-modified-message = Esta página foi escrita usando tinta inalterável.
